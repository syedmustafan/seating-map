# interactive-seating-map — example environment. Copy to .env.local to enable
# the optional backend integration. With NO env set (the default), the app loads
# the bundled public/venue.json and behaves exactly as the standalone submission.

# Point the venue loader at the user-data-api backend. When set, the app fetches
# the venue from `${VITE_API_BASE_URL}/venue` (through the backend cache + rate
# limiter) and the UI shows a "data: API" badge. Leave unset for static mode.
VITE_API_BASE_URL=http://localhost:4000
